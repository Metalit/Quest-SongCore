{
  "$schema": "https://raw.githubusercontent.com/QuestPackageManager/QPM.Package/refs/heads/main/qpm.schema.json",
  "version": "0.1.0",
  "sharedDir": "shared",
  "dependenciesDir": "extern",
  "info": {
    "name": "Quest-SongCore",
    "id": "songcore",
    "version": "1.2.2",
    "url": "https://github.com/raineio/quest-songcore",
    "additionalData": {
      "overrideSoName": "libsongcore.so",
      "cmake": true
    }
  },
  "workspace": {
    "scripts": {
      "build": [
        "python ./extern/includes/mod-scripts/shared/build.py $0:?"
      ],
      "copy": [
        "qpm s build",
        "python ./extern/includes/mod-scripts/shared/cpy.py $0:?"
      ],
      "debug": [
        "python ./extern/includes/mod-scripts/shared/dbg.py $0:?"
      ],
      "log": [
        "python ./extern/includes/mod-scripts/shared/log.py -t SongCore $0:?"
      ],
      "profile": [
        "python ./extern/includes/mod-scripts/shared/profile.py $0:?"
      ],
      "restart": [
        "python ./extern/includes/mod-scripts/shared/restart.py $0:?"
      ]
    },
    "ndk": "^29.0.14206865",
    "qmodIncludeDirs": [
      "./build"
    ],
    "qmodIncludeFiles": [],
    "qmodOutput": "SongCore"
  },
  "dependencies": [
    {
      "id": "beatsaber-hook",
      "versionRange": "^8.0.0",
      "additionalData": {}
    },
    {
      "id": "paper2_scotland2",
      "versionRange": "^4.7.0",
      "additionalData": {}
    },
    {
      "id": "bs-cordl",
      "versionRange": "^4203.0.0",
      "additionalData": {}
    },
    {
      "id": "bsml",
      "versionRange": "^0.5.2",
      "additionalData": {
        "private": true
      }
    },
    {
      "id": "lapiz",
      "versionRange": "^0.3.0",
      "additionalData": {
        "private": true
      }
    },
    {
      "id": "custom-types",
      "versionRange": "^0.20.0",
      "additionalData": {}
    },
    {
      "id": "scotland2",
      "versionRange": "^0.1.7",
      "additionalData": {
        "includeQmod": false,
        "private": true
      }
    },
    {
      "id": "libcryptopp",
      "versionRange": "^8.5.0",
      "additionalData": {
        "private": true
      }
    },
    {
      "id": "flamingo",
      "versionRange": "^1.1.2",
      "additionalData": {}
    },
    {
      "id": "metacore",
      "versionRange": "^2.0.0",
      "additionalData": {}
    },
    {
      "id": "mod-scripts",
      "versionRange": "^1.0.1",
      "additionalData": {}
    }
  ]
}
